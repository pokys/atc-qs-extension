{
  "manifest_version": 2,
  "name": "ATC → Alza 👽",
  "version": "1.0.6.1",
  "description": "Okamžité vyhledání Part# z ATCompu na Alze, TSBohemii, EDshopu a Heuréce.",

  "icons": {
    "32": "icon-32.png",
    "48": "icon-48.png",
    "96": "icon-96.png"
  },

  "browser_action": {
    "default_title": "ATC → Alza (ON/OFF)",
    "default_icon": {
      "32": "icon-32.png",
      "48": "icon-48.png"
    }
  },

  "background": {
    "scripts": ["background.js"]
  },

  "permissions": ["storage"],

  "content_scripts": [
    {
      "matches": ["*://*.atcomp.cz/*", "*://www.comfor.cz/*", "*://edshop.edsystem.cz/*"],
      "js": ["content.js"]
    }
  ],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "atc-qs@tb",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
